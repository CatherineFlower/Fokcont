<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Момент осознанности"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/interruptionDescText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Вы собирались открыть отвлекающее приложение. Хотите сделать паузу или вернуться к задаче?"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/workButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Вернуться к работе"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            android:backgroundTint="@color/primary"
            android:textColor="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/breathButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Дыхательное упражнение"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            android:background="@drawable/bg_secondary_button"
            app:backgroundTint="@null"
            android:textColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/audioButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Прослушать аудиофрагмент"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            android:background="@drawable/bg_secondary_button"
            app:backgroundTint="@null"
            android:textColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/notesButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Открыть заметки"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            android:background="@drawable/bg_secondary_button"
            app:backgroundTint="@null"
            android:textColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/continueButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Все равно продолжить"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

</LinearLayout>
